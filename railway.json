{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "/bin/sh -c \"exec node node_modules/srvx/bin/srvx.mjs serve --prod --host 0.0.0.0 --dir . --static dist/client --entry dist/server/server.js\"",
    "healthcheckPath": "/",
    "healthcheckTimeout": 180
  }
}
